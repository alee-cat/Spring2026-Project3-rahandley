@using Spring2026_Project3_rahandley.Models.ViewModels
@model ActorDetailsViewModel

@{
    ViewData["Title"] = "Details";
}

<h1>@Model.Actor.Name</h1>

<div>
    <h4>Actor</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Name</dt>
        <dd class="col-sm-10">@Model.Actor.Name</dd>

        <dt class="col-sm-2">Gender</dt>
        <dd class="col-sm-10">@Model.Actor.Gender</dd>

        <dt class="col-sm-2">Age</dt>
        <dd class="col-sm-10">@Model.Actor.Age</dd>

        <dt class="col-sm-2">IMDB</dt>
        <dd class="col-sm-10">
            <a href="@Model.Actor.ImdbLink" target="_blank">View</a>
        </dd>
    </dl>
</div>

<div>
    <a asp-action="Edit" asp-route-id="@Model.Actor.Id">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>

<hr />

<h3>Movies</h3>
<ul>
    @foreach (var movie in Model.Movies)
    {
        <li>@movie.Title</li>
    }
</ul>

<hr />

<h3>AI Tweets</h3>

<h4>Average Sentiment: @Model.AverageSentiment</h4>

<table class="table">
    <thead>
    <tr>
        <th>Tweet</th>
        <th>Sentiment</th>
    </tr>
    </thead>
    <tbody>
    @for (int i = 0; i < Model.Tweets.Count; i++)
    {
        <tr>
            <td>@Model.Tweets[i]</td>
            <td>@Model.Sentiments[i]</td>
        </tr>
    }
    </tbody>
</table>